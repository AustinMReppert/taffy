<test name="block_absolute_replaced_intrinsic_size__content_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="block" box-sizing="content-box" direction="ltr" width="200px" height="200px">
      <img src="../assets/blue15x15.png" box-sizing="content-box" direction="ltr" position="absolute"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="200" height="200">
      <node x="0" y="0" width="15" height="15"/>
    </node>
  </expectations>
</test>
